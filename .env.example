#  Copy to `.env` and adjust for the host. Used by docker-compose.yml.

#  Compose project name (prefixes the container name).
COMPOSE_PROJECT_NAME=omnipath-server

#  Database connection.
POSTGRES_DB=omnipath
POSTGRES_USER=omnipath
POSTGRES_PASSWORD=omnipath123
#  Host port the database is published on (container always listens on 5432).
POSTGRES_PORT=5486

#  Memory tuning (generous defaults for the ~2 GB interactions/annotations tables).
POSTGRES_SHM_SIZE=2gb
POSTGRES_SHARED_BUFFERS=4GB
POSTGRES_EFFECTIVE_CACHE_SIZE=12GB
POSTGRES_WORK_MEM=512MB
POSTGRES_MAINTENANCE_WORK_MEM=2GB
POSTGRES_MAX_WAL_SIZE=8GB
